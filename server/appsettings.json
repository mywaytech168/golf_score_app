{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "NLog": {
    "targets": {
      "logfile": {
        "type": "File",
        "fileName": "logs/${shortdate}.log",
        "layout": "${longdate} ${uppercase:${level}} ${message} ${exception:format=ToString}"
      },
      "logconsole": {
        "type": "Console",
        "layout": "${longdate} ${uppercase:${level}} ${message} ${exception}"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "logfile,logconsole"
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=10.1.1.25,3306;Database=golfscoreapp;User=root;Password=1qaz@WSX;"
  },
  "FileStorage": {
    "BaseDirectory": "\\\\10.1.1.101\\TekSwing",
    "VideoDirectory": "videos",
    "UploadDirectory": "uploads",
    "MaxFileSize": 5368709120,
    "AllowedExtensions": [ ".mp4", ".csv" ]
  },
  "Jwt": {
    "Secret": "your-very-long-secret-key-for-jwt-token-please-change-this-in-production-environment-at-least-32-characters",
    "Issuer": "GolfScoreApp",
