{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "NLog": {
    "targets": {
      "logfile": {
        "type": "File",
        "fileName": "logs/${shortdate}.log",
        "layout": "${longdate} ${uppercase:${level}} ${message} ${exception:format=ToString}"
      },
      "logconsole": {
        "type": "Console",
        "layout": "${longdate} ${uppercase:${level}} ${message} ${exception}"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "logfile,logconsole"
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_DB_HOST,3306;Database=golfscoreapp;User=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_RANDOM_32_CHARS",
    "Issuer": "GolfScoreApp",
    "Audience": "GolfScoreAppUsers",
    "ExpiryMinutes": 60
  },
  "Google": {
    "AndroidClientId": "YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com"
  },
  "GooglePlay": {
    "PackageName": "com.aethertek.orvia",
    "ServiceAccountJson": "",
    "TestMode": true,
    "TestTokens": [ "android.test.purchased", "test_purchased" ]
  },
  "GooglePay": {
    "TestMode": true
  },
  "AppStore": {
    "SharedSecret": "",
    "Sandbox": true
  },
  "Admin": {
    "SecretKey": "CHANGE_ME_ADMIN_SECRET",
    "Username": "admin",
    "Password": "CHANGE_ME_ADMIN_PASSWORD"
  },
  "App": {
    "BaseUrl": "https://orvia.api.atk.tw",
    "ApkMaxMb": 500
  },
  "Callback": {
    "Secret": ""
  },
  "B2": {
    "KeyId": "YOUR_B2_KEY_ID",
    "ApplicationKey": "YOUR_B2_APPLICATION_KEY",
    "BucketName": "orvia",
    "Endpoint": "https://s3.us-east-005.backblazeb2.com",
    "SharePrefix": "shares/"
  },
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Model": "gemini-3.5-flash",
    "V2Fps": 24,
    "V2Resolution": "MEDIA_RESOLUTION_HIGH"
  },
  "Smtp": {
    "Host": "mail.example.com",
    "Port": "465",
    "Username": "YOUR_SMTP_USER",
    "Password": "YOUR_SMTP_PASSWORD",
    "From": "service@example.com",
    "FromName": "ORVIA"
  },
  "GolfSwing": {
    "ModelPath": "models/pose_error_tcn.onnx"
  },
  "BallTrajectory": {
    "FlaskUrl": "http://YOUR_FLASK_HOST:6001",
    "TimeoutSec": 120
  }
}
