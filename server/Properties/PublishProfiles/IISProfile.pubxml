<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>http://10.1.1.35:9600</SiteUrlToLaunchAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <ProjectGuid>ba0e7e52-6459-10ab-9034-fd004ac71e6f</ProjectGuid>
    <SelfContained>false</SelfContained>
    <MSDeployServiceURL>https://10.1.1.35:8172/msdeploy.axd</MSDeployServiceURL>
    <!-- 2026-06-12 伺服器 IIS 站台已改名為 ORVIA（WMSvc 探測 404=存在）。
         站台名若再變動，先用 curl -k -u … "https://10.1.1.35:8172/msdeploy.axd?site=<名稱>"
         探測（404=存在、550=不存在），否則 msdeploy 只會回 -1 難以診斷。 -->
    <DeployIisAppPath>ORVIA</DeployIisAppPath>
    <RemoteSitePhysicalPath />
    <SkipExtraFilesOnServer>true</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>true</EnableMSDeployBackup>
    <EnableMsDeployAppOffline>true</EnableMsDeployAppOffline>
    <UserName>Administrator</UserName>
    <Password>myway@168</Password>
    <_SavePWD>true</_SavePWD>
    <AllowUntrustedCertificate>true</AllowUntrustedCertificate>
    <_TargetId>IISWebDeploy</_TargetId>
  </PropertyGroup>
</Project>