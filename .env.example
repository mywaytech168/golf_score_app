# Phase 5 - 环境变量配置示例

# ============ 消息队列配置 ============

# RabbitMQ 主机
MQ_HOST=localhost

# RabbitMQ 端口
MQ_PORT=5672

# RabbitMQ 用户名
MQ_USER=guest

# RabbitMQ 密码
MQ_PASS=guest

# ============ Worker 配置 ============

# Worker 工作模式: sync, async, batch, stream
WORKER_MODE=async

# Worker 并发数
WORKER_CONCURRENCY=4

# Worker 任务超时时间 (秒)
WORKER_TIMEOUT=300

# ============ 缓存配置 ============

# Redis 主机
CACHE_HOST=localhost

# Redis 端口
CACHE_PORT=6379

# Redis 数据库编号
CACHE_DB=0

# Redis TTL (秒)
CACHE_TTL=3600

# ============ 数据库配置 ============

# 主数据库 URL
DATABASE_URL=postgresql://user:password@localhost:5432/meshflow

# 从数据库 URL (可选,用逗号分隔多个)
DATABASE_SLAVE_URLS=postgresql://user:password@slave1:5432/meshflow,postgresql://user:password@slave2:5432/meshflow

# 数据库连接池大小
DATABASE_POOL_SIZE=20

# 从从数据库读取 (true/false)
DATABASE_READ_FROM_SLAVE=true

# ============ 负载均衡配置 ============

# 负载均衡策略: round_robin, least_connections, weighted_round_robin, ip_hash, random
LOAD_BALANCER_STRATEGY=round_robin

# 负载均衡最大重试次数
LOAD_BALANCER_MAX_RETRIES=3

# ============ 故障转移配置 ============

# 启用故障转移 (true/false)
FAILOVER_ENABLED=true

# 故障转移策略: immediate, graceful, delayed
FAILOVER_STRATEGY=graceful

# 故障转移超时时间 (秒)
FAILOVER_TIMEOUT=30

# ============ 监控配置 ============

# 启用监控 (true/false)
ENABLE_MONITORING=true

# Prometheus 端口
PROMETHEUS_PORT=9090

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 启用分布式追踪 (true/false)
ENABLE_DISTRIBUTED_TRACE=true

# Jaeger Agent 主机
JAEGER_AGENT_HOST=localhost

# Jaeger Agent 端口
JAEGER_AGENT_PORT=6831

# 采样率 (0-1)
SAMPLE_RATE=0.1

# ============ 应用配置 ============

# 应用环境: development, staging, production
APP_ENV=development

# 应用名称
APP_NAME=meshflow

# 应用版本
APP_VERSION=1.0.0

# 配置文件路径
CONFIG_FILE=config.json

# ============ 开发配置 ============

# 调试模式 (true/false)
DEBUG=false

# 自动重新加载 (true/false)
AUTO_RELOAD=false

# ============ 高级配置 ============

# 最大消息体大小 (字节)
MAX_MESSAGE_SIZE=10485760

# 消息过期时间 (毫秒)
MESSAGE_EXPIRATION=3600000

# 连接超时时间 (秒)
CONNECTION_TIMEOUT=30

# 读取超时时间 (秒)
READ_TIMEOUT=30

# 写入超时时间 (秒)
WRITE_TIMEOUT=30

# ============ 使用说明 ============

# 1. 复制此文件为 .env
#    cp .env.example .env

# 2. 根据实际环境修改参数

# 3. 在应用中加载:
#    from distributed_config import DistributedConfigManager
#    config = DistributedConfigManager()
#    # 从环境变量自动加载

# 4. 或者手动加载:
#    import os
#    from dotenv import load_dotenv
#    load_dotenv('.env')
#    config = DistributedConfigManager()
