# Uncomment this line to define a global platform for your project
platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  # Pin GTMSessionFetcher to 3.x — GoogleSignIn ~> 8.0 and MLKitVision both require < 4.0
  pod 'GTMSessionFetcher', '~> 3.4'

  # MediaPipe Tasks Vision（AVFoundation 即時 Pose Landmarker）
  pod 'MediaPipeTasksVision', '~> 0.10.14'

  # TFLite Swift API — YOLOv8n 高爾夫球偵測（iOS 側推論）
  # 2.17：需與 MediaPipeTasksCommon 內建 TFLite 版本相容
  # （subgraph.o 引用 TfLiteTensorClone 等 2.16+ 新增的 C API）
  pod 'TensorFlowLiteSwift', '~> 2.17.0'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Flutter 原本需要的設定（一定要留）
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # 強制所有 Pods 使用 iOS 15.5（解 Xcode 26 問題）
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'

      # 排除舊版 32-bit 架構
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
    end
  end

  # ── 解 MediaPipeTasksCommon × TensorFlowLiteC 重複符號（48 duplicate symbols）──
  # 兩者都內含 TFLite C API；MediaPipe 內建版本較新（引用 TfLiteTensorClone 等
  # pod 版 TensorFlowLiteC 沒有的符號），不能刪 MediaPipe 側。
  # strip_tflite_dups.py 改將 TensorFlowLiteC.framework 內與 MediaPipe 重複的
  # 全域符號降為 local（ld -r -unexported_symbols_list），兩份 TFLite 各自內聚。
  graph_libs = Dir.glob(File.join(__dir__, 'Pods', 'MediaPipeTasksCommon',
                                  'frameworks', 'graph_libraries', '*.a'))
  tflc_bins = Dir.glob(File.join(__dir__, 'Pods', 'TensorFlowLiteC', 'Frameworks',
                                 '**', 'TensorFlowLiteC.framework', 'TensorFlowLiteC'))
  unless graph_libs.empty? || tflc_bins.empty?
    tflc_bins.each do |bin|
      system('python3', File.join(__dir__, 'strip_tflite_dups.py'), bin, *graph_libs) \
        or raise "strip_tflite_dups failed for #{bin}"
    end
  end
end

