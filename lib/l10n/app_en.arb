  "termsAgreePrefix": "I have read and agree to the Terms of Service and the ",
  "termsPrivacyLink": "Privacy Policy",
  "termsAgreeSuffix": "》",
  "termsAnalyticsTitle": "Allow usage analytics (optional)",
  "termsAnalyticsDesc": "Helps us improve the app experience. No personally identifiable information is included.",
  "termsScrollFirst": "Please scroll through the full terms before checking the agreement box",
